# Copy this file to .env and fill in real values.

# MongoDB connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=ecommerce

# Public base URL of the deployed app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins, or * for all
CORS_ORIGINS=*

# Used to sign session cookies — set a long random string in production
AUTH_SECRET=change_me_in_prod_super_secret_string_12345

# SMTP for real OTP emails (signup verification, password reset).
# Leave blank to keep using on-screen dev codes instead of real email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
