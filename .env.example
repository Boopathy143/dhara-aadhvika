# .env.example — Dhara Aadhvika
# Copy this file to `.env` inside /app/frontend and fill in real values.
# Never commit your real .env. It is gitignored.

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string. For MongoDB Atlas it looks like:
#   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
# For local development, use:
#   mongodb://localhost:27017
MONGO_URL=mongodb://localhost:27017

# Database name. Application creates this DB on first connect.
DB_NAME=ecommerce

# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC SITE URL — REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Production URL. Used by:
#   • next.js metadataBase (OpenGraph, Twitter card, canonical URLs)
#   • dynamic /sitemap.xml
#   • /robots.txt
#   • password-reset and OTP email links
# In Vercel set this in Production environment to your real domain.
NEXT_PUBLIC_BASE_URL=https://dharaaadhvika.in

# ─────────────────────────────────────────────────────────────────────────────
# AUTH — REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Reserved for future token signing. Currently the app uses opaque cookie
# sessions stored in MongoDB, so this is not actively read — but keep it set
# to a strong random string so future upgrades don't break.
# Generate with:  openssl rand -hex 32
AUTH_SECRET=replace-with-openssl-rand-hex-32

# ─────────────────────────────────────────────────────────────────────────────
# CORS — OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins. Reserved for future API hardening
# (current build does not enforce CORS — same-origin only).
CORS_ORIGINS=https://dharaaadhvika.in,https://www.dharaaadhvika.in

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL / SMTP — REQUIRED (for OTP signup, login OTP, password reset)
# ─────────────────────────────────────────────────────────────────────────────

# Gmail SMTP (recommended for ≤500 emails/day):
#   1. Enable 2FA on dharaaadhvika@gmail.com
#   2. Generate an app password at https://myaccount.google.com/apppasswords
#   3. Paste the 16-character password (spaces are fine) below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dharaaadhvika@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# OPTIONAL — friendly "From" header. Defaults to SMTP_USER if blank.
SMTP_FROM=Dhara Aadhvika <dharaaadhvika@gmail.com>

# ─────────────────────────────────────────────────────────────────────────────
# NODE_ENV — set automatically by hosts (Vercel/Render/Railway)
# ─────────────────────────────────────────────────────────────────────────────
# NODE_ENV=production
